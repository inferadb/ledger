{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "just fmt-check || true"
          },
          {
            "type": "command",
            "command": "just clippy || true"
          },
          {
            "type": "command",
            "command": "just doc-check || true"
          }
        ]
      }
    ]
  }
}
