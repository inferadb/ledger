      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(ledger_grpc_requests_total{service=\"WriteService\", status=\"OK\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ledger_grpc_requests_total{service=\"WriteService\", status!=\"OK\"}[5m]))",
          "legendFormat": "Error",
          "refId": "B"
        }
      ],
